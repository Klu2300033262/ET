# Environment
ENV=development
LOG_LEVEL=INFO

# FastAPI Configs
HOST=127.0.0.1
PORT=8000

# Google Gemini API Configs
GEMINI_API_KEY=your_gemini_api_key_here

# Neo4j Graph DB Configs
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=password

# ChromaDB Configurations (Persistent Path)
CHROMA_PERSIST_DIR=./data/chromadb
